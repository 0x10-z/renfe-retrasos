---
interface StationMeta {
  lat: number;
  lng: number;
  provincia: string;
  poblacion: string;
  direcion?: string;
  cp?: string;
  cercanias: boolean;
}

interface Props {
  id: string;
  name: string;
  dataName: string;    // "ave-larga-distancia" | "cercanias"  — data folder
  serviceSlug: string; // "ave-larga-distancia" | "cercanias"  — URL segment
  serviceLabel: string;
  meta?: StationMeta | null;
}

const { id, name, dataName, serviceSlug, serviceLabel, meta } = Astro.props;
const osmUrl = meta ? `https://www.openstreetmap.org/?mlat=${meta.lat}&mlon=${meta.lng}&zoom=15` : null;
const locationLabel = meta
  ? [meta.poblacion, meta.provincia].filter(Boolean).join(", ")
  : null;
---

<style>
  .train-preview-license {
    font-size: 0.62rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
</style>

<div
  class="station-page"
  data-id={id}
  data-service={dataName}
  data-name={name}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Navegación">
    <a href="/">Inicio</a>
    <span class="bc-sep">›</span>
    <a href={`/#${serviceSlug}`}>{serviceLabel}</a>
    <span class="bc-sep">›</span>
    <span id="bc-station">{name}</span>
  </nav>

  <!-- Station header -->
  <div class="station-header">
    <div class="station-title-wrap">
      <div class="station-dot-lg" id="header-dot"></div>
      <div>
        <h1 id="station-name">{name}</h1>
        {locationLabel && (
          <p class="station-location">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {osmUrl
              ? <a href={osmUrl} target="_blank" rel="noopener" class="location-link">{locationLabel}</a>
              : locationLabel}
            {meta?.direcion && <span class="station-address">· {meta.direcion}{meta.cp ? `, ${meta.cp}` : ""}</span>}
          </p>
        )}
        <p class="station-meta" id="arrivals-meta">Cargando llegadas…</p>
      </div>
    </div>
    <div class="header-right">
      <div class="summary-chips" id="summary-chips"></div>
      <div class="refresh-info">
        <span id="last-updated" class="muted">…</span>
        <div class="refresh-bar-wrap">
          <div id="refresh-bar" class="refresh-bar"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Board -->
  <div class="board-wrap" id="board-wrap">
    <table class="board" id="arrivals-board">
      <thead>
        <tr>
          <th>Tren / Origen → Destino</th>
          <th>Programada</th>
          <th>Estimada</th>
          <th>Retraso</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody id="arrivals-body">
        {[0,1,2,3,4].map(() => (
          <tr class="skeleton-row">
            <td colspan="5"><div class="skeleton-cell"></div></td>
          </tr>
        ))}
      </tbody>
    </table>

    <div id="no-arrivals" class="empty-state" style="display:none">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.25"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>
      <p>Sin llegadas en los próximos 60 minutos</p>
    </div>

    <div id="error-state" class="empty-state" style="display:none">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.25"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/></svg>
      <p>No se pudieron cargar los datos.</p>
      <button onclick="window.location.reload()">Reintentar</button>
    </div>
  </div>

    <div class="train-preview" id="train-preview" style="display:none">
      <div class="train-preview-img-wrap">
        <img id="train-preview-image" class="train-preview-image" src="" alt="Serie aproximada del tren" loading="lazy" />
      </div>
      <div class="train-preview-copy">
        <p class="train-preview-helper">Pasa el raton o pulsa una fila para actualizar la serie aproximada.</p>
        <p id="train-preview-type" class="train-preview-type">Tren</p>
        <p id="train-preview-name" class="train-preview-name">Servicio detectado: -</p>
        <p class="train-preview-note">Renfe utiliza distintas series de tren. La imagen es aproximada y puede no coincidir al 100% con la composicion real del servicio.</p>
          <p class="train-preview-license">Foto tomada de Wikipedia bajo licencia <a href="https://creativecommons.org/licenses/by-sa/3.0/deed.es" target="_blank" rel="noopener noreferrer">CC BY-SA 3.0</a>.</p>
      </div>
    </div>

    {meta && (
      <div class="location-section">
        <div class="location-section-header">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Ubicación
        </div>
        <div
          id="station-mini-map"
          class="mini-map"
          data-lat={meta.lat}
          data-lng={meta.lng}
          data-osm={osmUrl}
          aria-label={`Mapa de ubicación de ${name}`}
        ></div>
      </div>
    )}

    <div id="train-viewer-modal" class="train-viewer-modal" style="display:none" role="dialog" aria-modal="true" aria-labelledby="train-viewer-title">
      <div class="train-viewer-panel">
        <button type="button" class="train-viewer-close" id="train-viewer-close" aria-label="Cerrar imagen ampliada">×</button>
        <img id="train-viewer-image" class="train-viewer-image" src="" alt="Foto aproximada de la serie de tren" loading="lazy" />
        <div class="train-viewer-info">
          <h3 id="train-viewer-title">Serie aproximada</h3>
          <p id="train-viewer-train-name" class="train-viewer-train-name">Servicio detectado: -</p>
          <p class="train-viewer-note">Renfe utiliza diferentes series de tren y esta foto es orientativa, por lo que puede no ajustarse al 100% al material exacto de cada servicio.</p>
          <p class="train-preview-license">Foto tomada de Wikipedia bajo licencia <a href="https://creativecommons.org/licenses/by-sa/3.0/deed.es" target="_blank" rel="noopener noreferrer">CC BY-SA 3.0</a>.</p>
        </div>
      </div>
    </div>
  </div>

<style>
  .station-page {
    max-width: 920px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-sub);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb a:hover { color: var(--accent); }
  .bc-sep { color: var(--border-bright); }
  #bc-station { color: var(--text); font-weight: 500; }

  /* Station header */
  .station-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.25rem;
    flex-wrap: wrap;
  }

  .station-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .station-dot-lg {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .station-dot-lg.has-delays { background: var(--yellow); }
  .station-dot-lg.has-high-delays { background: var(--red); }

  .station-location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    flex-wrap: wrap;
  }
  .station-location svg { flex-shrink: 0; color: var(--accent); }
  .location-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .location-link:hover { color: var(--accent); text-decoration: underline; }
  .station-address {
    color: var(--text-sub);
    font-size: 0.73rem;
  }

  .station-meta {
    font-size: 0.8rem;
    color: var(--text-sub);
  }

  .location-section {
    margin-top: 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.85rem 0.9rem;
    box-shadow: var(--shadow-sm);
  }

  .location-section-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
    margin-bottom: 0.65rem;
  }
  .location-section-header svg { color: var(--accent); }

  .mini-map {
    width: 100%;
    height: 240px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
  }

  .summary-chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 640px) {
    .summary-chips { justify-content: flex-start; }
    .refresh-info { text-align: left; }
    .refresh-bar-wrap { margin-left: 0; margin-right: 0; }
    .mini-map { height: 180px; }
  }

  :global(.chip) {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-mono);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
    white-space: nowrap;
  }
  :global(.chip-green)  { background: var(--green-bg);  color: var(--green);  }
  :global(.chip-yellow) { background: var(--yellow-bg); color: var(--yellow); }
  :global(.chip-red)    { background: var(--red-bg);    color: var(--red);    }
  :global(.chip-gray)   { background: var(--bg);        color: var(--text-muted); border: 1px solid var(--border); }

  .refresh-info { font-size: 0.75rem; color: var(--text-sub); text-align: right; margin-top: 0.25rem; }
  .refresh-bar-wrap {
    width: 90px; height: 2px;
    background: var(--border); border-radius: 1px;
    margin-top: 0.4rem; margin-left: auto; overflow: hidden;
  }
  .refresh-bar {
    height: 100%; background: var(--accent); width: 100%;
    transform-origin: left; transition: transform linear;
  }

  /* Board */
  .board-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .board { width: 100%; border-collapse: collapse; font-size: 0.875rem; }

  .board thead tr {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .board th {
    padding: 0.85rem 1.25rem;
    text-align: left;
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }
  :global(.board td) {
    padding: 1.0rem 1.25rem;
    border-bottom: 2px solid var(--border);
    vertical-align: middle;
  }
  :global(.board tbody tr:last-child td) { border-bottom: none; }
  :global(.board tbody tr:hover td) { background: var(--bg-card-hover); }

  /* Col widths */
  :global(.board th:nth-child(1)), :global(.board td:nth-child(1)) { min-width: 200px; }
  :global(.board th:nth-child(2)), :global(.board td:nth-child(2)),
  :global(.board th:nth-child(3)), :global(.board td:nth-child(3)) { width: 110px; font-family: var(--font-mono); }
  :global(.board th:nth-child(4)), :global(.board td:nth-child(4)) { width: 80px; }
  :global(.board th:nth-child(5)), :global(.board td:nth-child(5)) { width: 140px; }

  :global(.time-cell) { font-family: var(--font-mono); font-size: 0.92rem; letter-spacing: 0.02em; }
  :global(.time-on-time) { color: var(--text); }
  :global(.time-leve)    { color: var(--yellow); font-weight: 500; }
  :global(.time-alto)    { color: var(--orange); font-weight: 600; }
  :global(.time-cancel)  { color: var(--text-sub); text-decoration: line-through; }

  :global(.delay-cell) { font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-sub); }
  :global(.delay-leve) { color: var(--yellow); font-weight: 500; }
  :global(.delay-alto) { color: var(--orange); font-weight: 600; }

  :global(.badge) {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.68rem; font-weight: 600;
    padding: 0.2rem 0.55rem; border-radius: 4px;
    letter-spacing: 0.04em; text-transform: uppercase;
    font-family: var(--font-mono); white-space: nowrap;
  }
    :global(.board tbody tr) {
      cursor: pointer;
      transition: background-color 0.15s;
    }
    :global(.board tbody tr:hover) {
      background-color: var(--bg-card-hover);
    }
  :global(.badge-en_hora)      { background: var(--green-bg);  color: var(--green);  border: 1px solid var(--green-border); }
  :global(.badge-retraso_leve) { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow-border); }
  :global(.badge-retraso_alto) { background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange-border); }
  :global(.badge-cancelado)    { background: var(--red-bg);    color: var(--red);    border: 1px solid var(--red-border); }

  :global(.origin-main) { font-weight: 500; font-size: 0.875rem; }
  :global(.origin-dest) { font-size: 0.72rem; color: var(--text-sub); margin-top: 0.1rem; }
  :global(.origin-from) { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.15rem; }
  :global(.route-sep) { color: var(--text-sub); margin-right: 0.2em; }
  :global(.route-tag) {
    display: inline-block; font-size: 0.63rem; font-family: var(--font-mono); font-weight: 700;
    background: var(--accent-bg); color: var(--accent);
    padding: 0.1rem 0.35rem; border-radius: 3px; margin-right: 0.35rem; vertical-align: middle;
  }
  :global(.cancelled-row td) { opacity: 0.55; }

  /* Skeleton */
  .skeleton-row td { padding: 0; border-bottom: 1px solid var(--border); }
  .skeleton-cell {
    height: 52px;
    background: linear-gradient(90deg, var(--bg) 25%, var(--border) 50%, var(--bg) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  .empty-state {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.75rem; padding: 3rem 1rem;
    color: var(--text-muted); font-size: 0.875rem; text-align: center;
  }
  .empty-state button {
    background: var(--accent-bg); color: var(--accent);
    border: 1px solid var(--accent-border);
    padding: 0.4rem 1.25rem; border-radius: var(--radius-sm);
    font-size: 0.82rem; cursor: pointer;
  }
  .empty-state button:hover { background: rgba(79,94,245,0.15); }

  .train-preview {
    margin-top: 0.9rem;
    border-top: 1px solid var(--border);
    padding: 0.85rem 0.9rem;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--bg-card);
  }

  .train-preview-img-wrap {
    width: 120px;
    height: 78px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
      /* Removed zoom/scale effect */
      cursor: pointer;
  }

  .train-preview-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
      /* Removed zoom/scale effect */
  }

    /* Removed zoom/scale effect on hover */

  .train-preview-copy {
    min-width: 0;
  }

  .train-preview-helper {
    font-size: 0.68rem;
    color: var(--text-sub);
    margin-bottom: 0.35rem;
  }

  .train-preview-type {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .train-preview-name {
    font-size: 0.72rem;
    color: var(--text);
    font-family: var(--font-mono);
    margin-bottom: 0.35rem;
  }

  .train-preview-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.35;
  }

  .train-viewer-modal {
    position: fixed;
    inset: 0;
    background: rgba(10, 15, 20, 0.78);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1200;
    padding: 1rem;
  }

  .train-viewer-panel {
    width: min(900px, 100%);
    max-height: 92vh;
    overflow: auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 0.9rem;
    position: relative;
  }

  .train-viewer-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-card);
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1;
  }

  .train-viewer-close:hover {
    color: var(--text);
    border-color: var(--border-bright);
  }

  .train-viewer-image {
    width: 100%;
    max-height: 65vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
  }

  .train-viewer-info {
    margin-top: 0.75rem;
  }

  .train-viewer-train-name {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--text);
    margin-top: 0.2rem;
  }

  .train-viewer-note {
    font-size: 0.74rem;
    color: var(--text-muted);
    margin-top: 0.45rem;
    line-height: 1.35;
  }

  @media (max-width: 640px) {
    :global(.board th:nth-child(4)), :global(.board td:nth-child(4)) { display: none; }
    :global(.board th), :global(.board td) { padding: 0.75rem 0.65rem; }
    .station-header { flex-direction: column; }
    .header-right { align-items: flex-start; }
    .summary-chips { justify-content: flex-start; }
    .train-preview {
      padding: 0.7rem;
      gap: 0.6rem;
    }
    .train-preview-img-wrap {
      width: 95px;
      height: 64px;
    }
  }
</style>

<script>
  const REFRESH_INTERVAL = 60_000;
  const TRAIN_IMAGE_MAP: Record<string, string> = {
    AVE: "/trenes/s112.webp",
    AVANT: "/trenes/s121.webp",
    MD: "/trenes/s449.webp",
    REGIONAL: "/trenes/s449.webp",
    CERCANIAS: "/trenes/civia.webp",
  };

  const TRAIN_TYPE_LABELS: Record<string, string> = {
    AVE: "AVE / Alta Velocidad",
    AVANT: "AVANT / Media Distancia",
    MD: "MD / Media Distancia",
    REGIONAL: "Regional",
    CERCANIAS: "Cercanias",
  };

  const root = document.querySelector<HTMLElement>(".station-page")!;
  const id = root.dataset.id!;
  const dataService = root.dataset.service!;
  const stationName = root.dataset.name!;
  const fetchUrl = () => `/data/${dataService}/stations/${encodeURIComponent(id)}.json?t=${Date.now()}`;

  let countdownTimer: ReturnType<typeof setInterval> | null = null;
  let nextRefreshAt = 0;
  let selectedTrainName = "";

  async function load() {
    try {
      const res = await fetch(fetchUrl());
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      render(await res.json());
    } catch {
      showError();
    }
  }

  function render(data: any) {
    const arrivals: any[] = data.arrivals ?? [];

    // Header meta
    setText("arrivals-meta",
      arrivals.length
        ? `${arrivals.length} llegada${arrivals.length !== 1 ? "s" : ""} · próximos 60 min`
        : "Sin llegadas próximas");
    setText("last-updated", `Actualizado ${timeAgo(data.generated_at)}`);

    // Summary chips
    const delayed = arrivals.filter(a => ["retraso_leve","retraso_alto"].includes(a.status));
    const cancelled = arrivals.filter(a => a.status === "cancelled");
    const maxDelay = Math.max(0, ...arrivals.map(a => a.delay_min ?? 0));
    const dot = document.getElementById("header-dot")!;

    if (delayed.length === 0 && cancelled.length === 0) {
      dot.className = "station-dot-lg";
    } else if (arrivals.filter(a => a.status === "retraso_alto").length > 0) {
      dot.className = "station-dot-lg has-high-delays";
    } else {
      dot.className = "station-dot-lg has-delays";
    }

    const chips: string[] = [];
    const onTime = arrivals.filter(a => a.status === "en_hora").length;
    if (onTime)       chips.push(`<span class="chip chip-green">${onTime} en hora</span>`);
    if (delayed.length) chips.push(`<span class="chip chip-yellow">${delayed.length} retrasado${delayed.length!==1?"s":""}</span>`);
    if (maxDelay > 0) chips.push(`<span class="chip chip-red">+${maxDelay}m máx</span>`);
    if (cancelled.length) chips.push(`<span class="chip chip-gray">${cancelled.length} cancelado${cancelled.length!==1?"s":""}</span>`);
    document.getElementById("summary-chips")!.innerHTML = chips.join("");

    // Table
    const body = document.getElementById("arrivals-body")!;
    if (!arrivals.length) {
      body.innerHTML = "";
      document.getElementById("no-arrivals")!.style.display = "flex";
      document.getElementById("train-preview")!.style.display = "none";
      return;
    }
    document.getElementById("no-arrivals")!.style.display = "none";
    body.innerHTML = arrivals.map(rowHTML).join("");
    attachTrainRowListeners(arrivals);
  }

  function attachTrainRowListeners(arrivals: any[]) {
    const preview = document.getElementById("train-preview") as HTMLElement;
    preview.style.display = "flex";

    const firstWithName = arrivals.find((a) => a.train_name) ?? arrivals[0];
    setTrainPreview(firstWithName?.train_name);

    const rows = document.querySelectorAll<HTMLTableRowElement>("#arrivals-body tr");
    rows.forEach((row) => {
      const updatePreview = () => setTrainPreview(row.dataset.trainName);
      row.addEventListener("mouseenter", updatePreview);
      row.addEventListener("click", updatePreview);
    });
  }

  function getTrainType(trainName?: string): string {
    if (!trainName) return "REGIONAL";
    const type = trainName.trim().split(/\s+/)[0]?.toUpperCase() ?? "REGIONAL";
    return TRAIN_IMAGE_MAP[type] ? type : "REGIONAL";
  }

  function setTrainPreview(trainName?: string) {
    const type = getTrainType(trainName);
    const image = document.getElementById("train-preview-image") as HTMLImageElement;
    const title = document.getElementById("train-preview-type") as HTMLElement;
    const name = document.getElementById("train-preview-name") as HTMLElement;
    selectedTrainName = trainName ?? "";
    image.src = TRAIN_IMAGE_MAP[type] ?? TRAIN_IMAGE_MAP.REGIONAL;
    title.textContent = TRAIN_TYPE_LABELS[type] ?? "Tren";
    name.textContent = `Servicio detectado: ${trainName ?? "-"}`;
  }

  function openTrainViewer() {
    const type = getTrainType(selectedTrainName);
    const modal = document.getElementById("train-viewer-modal") as HTMLElement;
    const image = document.getElementById("train-viewer-image") as HTMLImageElement;
    const title = document.getElementById("train-viewer-title") as HTMLElement;
    const name = document.getElementById("train-viewer-train-name") as HTMLElement;

    image.src = TRAIN_IMAGE_MAP[type] ?? TRAIN_IMAGE_MAP.REGIONAL;
    title.textContent = TRAIN_TYPE_LABELS[type] ?? "Serie aproximada";
    name.textContent = `Servicio detectado: ${selectedTrainName || "-"}`;
    modal.style.display = "flex";
    document.body.style.overflow = "hidden";
  }

  function closeTrainViewer() {
    const modal = document.getElementById("train-viewer-modal") as HTMLElement;
    modal.style.display = "none";
    document.body.style.overflow = "";
  }

  function rowHTML(a: any): string {
    const statusLabel: Record<string, string> = {
      en_hora: "En hora", retraso_leve: "Leve", retraso_alto: "Alto", cancelado: "Cancelado",
    };
    const timeClass: Record<string, string> = {
      en_hora: "time-on-time", retraso_leve: "time-leve", retraso_alto: "time-alto", cancelado: "time-cancel",
    };

    const routeTag = (a.train_name || a.route_id) ? `<span class="route-tag">${esc(a.train_name || a.route_id)}</span>` : "";
    const destText = a.headsign || a.origin || "—";
    const fromLine = a.origin && a.origin !== stationName && a.origin !== destText
      ? `<div class="origin-from"><span class="route-sep">desde</span> ${esc(a.origin)}</div>`
      : "";
    const origin = `<div class="origin-main">${routeTag}${esc(destText)}</div>${fromLine}`;
    const dest = "";

    const estTime = a.estimated_time
      ? `<span class="time-cell ${timeClass[a.status] ?? ""}">${esc(a.estimated_time)}</span>`
      : `<span class="time-cell time-cancel">—</span>`;

    const delayStr = a.delay_min != null && a.delay_min > 0 ? `+${a.delay_min}m` : "—";
    const delayClass = a.status === "retraso_alto" ? "delay-alto" : a.status === "retraso_leve" ? "delay-leve" : "";
    const rowClass = a.status === "cancelado" ? "cancelled-row" : "";
    const trainNameAttr = a.train_name ? `data-train-name="${esc(a.train_name)}"` : "";

    return `<tr class="${rowClass}" ${trainNameAttr}>
      <td><div>${origin}${dest}</div></td>
      <td><span class="time-cell">${esc(a.scheduled_time ?? "—")}</span></td>
      <td>${estTime}</td>
      <td><span class="delay-cell ${delayClass}">${delayStr}</span></td>
      <td><span class="badge badge-${a.status ?? "en_hora"}">● ${esc(statusLabel[a.status] ?? a.status)}</span></td>
    </tr>`;
  }

  function showError() {
    document.getElementById("arrivals-body")!.innerHTML = "";
    document.getElementById("error-state")!.style.display = "flex";
  }

  function startCountdown() {
    nextRefreshAt = Date.now() + REFRESH_INTERVAL;
    const bar = document.getElementById("refresh-bar") as HTMLElement;
    if (countdownTimer) clearInterval(countdownTimer);
    countdownTimer = setInterval(() => {
      bar.style.transform = `scaleX(${Math.max(0, nextRefreshAt - Date.now()) / REFRESH_INTERVAL})`;
    }, 500);
  }

  function timeAgo(iso: string): string {
    const d = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
    if (d < 5) return "ahora mismo";
    if (d < 60) return `hace ${d}s`;
    if (d < 3600) return `hace ${Math.floor(d / 60)}m`;
    return "hace >1h";
  }

  function setText(id: string, v: string) {
    const el = document.getElementById(id); if (el) el.textContent = v;
  }

  function esc(s: string): string {
    return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]!));
  }

  document.querySelector(".train-preview-img-wrap")?.addEventListener("click", openTrainViewer);
  document.getElementById("train-viewer-close")?.addEventListener("click", closeTrainViewer);
  document.getElementById("train-viewer-modal")?.addEventListener("click", (e) => {
    if (e.target === document.getElementById("train-viewer-modal")) closeTrainViewer();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && (document.getElementById("train-viewer-modal") as HTMLElement).style.display !== "none") {
      closeTrainViewer();
    }
  });

  load();
  startCountdown();
  setInterval(() => { load(); startCountdown(); }, REFRESH_INTERVAL);

  // ── Mini map ────────────────────────────────────────────────────────────────
  const miniMapEl = document.getElementById("station-mini-map") as HTMLElement | null;
  if (miniMapEl) {
    const lat = parseFloat(miniMapEl.dataset.lat!);
    const lng = parseFloat(miniMapEl.dataset.lng!);
    const osmHref = miniMapEl.dataset.osm!;

    Promise.all([
      import("leaflet/dist/leaflet.css"),
      import("leaflet"),
    ]).then(([, leafletModule]) => {
      const L = (leafletModule as any).default ?? leafletModule;
      const map = L.map(miniMapEl, {
        center: [lat, lng],
        zoom: 14,
        zoomControl: false,
        attributionControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        touchZoom: false,
      });

      L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
        subdomains: "abcd",
        maxZoom: 19,
      }).addTo(map);

      L.circleMarker([lat, lng], {
        radius: 7,
        fillColor: "#0d9488",
        color: "#fff",
        weight: 2,
        fillOpacity: 1,
      }).addTo(map);

      miniMapEl.addEventListener("click", () => window.open(osmHref, "_blank", "noopener"));
    });
  }
</script>
