---
import { readFileSync } from "fs";
import { resolve } from "path";
import Layout from "../../layouts/Layout.astro";
import StationBoard from "../../components/StationBoard.astro";

export function getStaticPaths() {
  try {
    const raw = readFileSync(resolve("public/data/ave-larga-distancia/stats.json"), "utf-8");
    const { stations } = JSON.parse(raw);
    let geo: Record<string, any> = {};
    try {
      geo = JSON.parse(readFileSync(resolve("public/data/stations_geo.json"), "utf-8"));
    } catch {}
    return stations.map((s: any) => ({
      params: { id: s.id },
      props: { name: s.name, meta: geo[s.id] ?? null },
    }));
  } catch {
    return [];
  }
}

const { id } = Astro.params;
const { name, meta } = Astro.props;
---

<Layout title={name}>
  <StationBoard
    id={id}
    name={name}
    dataName="ave-larga-distancia"
    serviceSlug="ave-larga-distancia"
    serviceLabel="AVE · Larga y Media Distancia"
    meta={meta}
  />
</Layout>
